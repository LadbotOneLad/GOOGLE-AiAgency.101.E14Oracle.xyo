class PostProcessorService(MCPService):
    """MCP interface for post-processing and snapping"""

    def __init__(self):
        super().__init__(ServiceType.POST_PROCESSOR)

    async def handle(self, request: MCPRequest) -> Any:
        method = request.method
        params = request.params

        if method == "snap_to_alignment":
            return await self.snap_to_alignment(params)
        elif method == "snap_to_integers":
            return await self.snap_to_integers(params)
        elif method == "snap_to_multiples":
            return await self.snap_to_multiples(params)
        else:
            raise ValueError(f"Unknown method: {method}")

    async def snap_to_alignment(self, params: Dict) -> Dict[str, Any]:
        """Snap predictions to alignment"""
        await asyncio.sleep(0.1)
        threshold = params.get('threshold', 0.98)
        predictions = params.get('predictions', [])
        snapped = [1.0 if p > threshold else p for p in predictions]
        return {
            'predictions_snapped': len([p for p in snapped if p == 1.0]),
            'snapped_predictions': snapped
        }

    async def snap_to_integers(self, params: Dict) -> Dict[str, Any]:
        """Snap to integers"""
        await asyncio.sleep(0.05)
        predictions = params.get('predictions', [])
        snapped = [round(p) for p in predictions]
        return {'snapped_predictions': snapped}

    async def snap_to_multiples(self, params: Dict) -> Dict[str, Any]:
        """Snap to multiples"""
        await asyncio.sleep(0.05)
        import numpy as np
        multiple = params.get('multiple', np.pi)
        predictions = params.get('predictions', [])
        snapped = [round(p / multiple) * multiple for p in predictions]
        return {'snapped_predictions': snapped}


class MCPClient:
    """Client for making MCP requests"""

    def __init__(self, router: MCPRouter):
        self.router = router
        self.request_counter = 0

    async def call(self, service: ServiceType, method: str, **kwargs) -> MCPResponse:
        """Make an MCP call"""
        self.request_counter += 1
        request = MCPRequest(
            service=service,
            method=method,
            params=kwargs,
            request_id=f"req-{self.request_counter}"
        )
        return await self.router.route(request)


