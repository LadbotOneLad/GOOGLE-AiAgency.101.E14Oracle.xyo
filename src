@dataclass
class MCPRequest:
    """Standard MCP request envelope"""
    service: ServiceType
    method: str
    params: Dict[str, Any]
    request_id: str
    timestamp: float = None

    def __post_init__(self):
        if self.timestamp is None:
            self.timestamp = time.time()


@dataclass
class MCPResponse:
    """Standard MCP response envelope"""
    request_id: str
    service: ServiceType
    success: bool
    data: Any
    error: Optional[str] = None
    timestamp: float = None
    execution_time_ms: float = None

    def __post_init__(self):
        if self.timestamp is None:
            self.timestamp = time.time()


class MCPRouter:
    """
    Central router for MCP protocol.
    Dispatches requests to appropriate service handlers.
    Maintains service registry and state.
    """

    def __init__(self):
        self.services: Dict[ServiceType, 'MCPService'] = {}
        self.request_log: List[MCPRequest] = []
        self.response_log: List[MCPResponse] = []
        self.service_health: Dict[ServiceType, bool] = {}

    def register_service(self, service_type: ServiceType, service: 'MCPService'):
        """Register a service with the router"""
        self.services[service_type] = service
        self.service_health[service_type] = True
        print(f"[OK] Registered {service_type.value}")

    async def route(self, request: MCPRequest) -> MCPResponse:
        """Route incoming request to appropriate service"""
        start_time = time.time()
        self.request_log.append(request)

        try:
            if request.service not in self.services:
                return MCPResponse(
                    request_id=request.request_id,
                    service=request.service,
                    success=False,
                    error=f"Service {request.service.value} not registered"
                )

            service = self.services[request.service]
            result = await service.handle(request)

            execution_time = (time.time() - start_time) * 1000
            response = MCPResponse(
                request_id=request.request_id,
                service=request.service,
                success=True,
                data=result,
                execution_time_ms=execution_time
            )

            self.response_log.append(response)
            return response

        except Exception as e:
            execution_time = (time.time() - start_time) * 1000
            response = MCPResponse(
                request_id=request.request_id,
                service=request.service,
                success=False,
                error=str(e),
                execution_time_ms=execution_time
            )
            self.response_log.append(response)
            return response

    def get_health_status(self) -> Dict[str, Any]:
        """Get health status of all services"""
        return {
            service.value: self.service_health.get(service, False)
            for service in ServiceType
        }

    def get_metrics(self) -> Dict[str, Any]:
        """Get aggregated metrics across all requests"""
        if not self.response_log:
            return {}

        execution_times = [r.execution_time_ms for r in self.response_log if r.execution_time_ms]
        success_count = sum(1 for r in self.response_log if r.success)
        error_count = len(self.response_log) - success_count

        return {
            'total_requests': len(self.request_log),
            'total_responses': len(self.response_log),
            'success_count': success_count,
            'error_count': error_count,
            'success_rate': success_count / len(self.response_log) if self.response_log else 0,
            'avg_execution_time_ms': sum(execution_times) / len(execution_times) if execution_times else 0,
            'min_execution_time_ms': min(execution_times) if execution_times else 0,
            'max_execution_time_ms': max(execution_times) if execution_times else 0,
        }


